# Vitrine TAS — configuration
# URL de base de ton backend TAS (là où tourne l'API). Le formulaire de contact
# envoie sur ${VITE_API_BASE}/api/public/contact.
#   - Dev local :  VITE_API_BASE=http://localhost:4000
#   - Test ngrok : VITE_API_BASE=https://xxxx.ngrok-free.app
#   - Prod :       VITE_API_BASE=https://app.tondomaine.com
# Copie ce fichier en `.env` (ou `.env.local`) et renseigne la valeur.
VITE_API_BASE=https://app.tondomaine.com
